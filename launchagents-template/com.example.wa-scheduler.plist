<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Template: WhatsApp scheduler LaunchAgent.
  Drains .state/wa-queue.json every 60s.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.example.wa-scheduler</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/node</string>
        <string>/Users/YOU/chief-of-staff/scripts/wa-scheduler.mjs</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>/Users/YOU</string>
        <key>PROJECT_ROOT</key>
        <string>/Users/YOU/chief-of-staff</string>
        <key>TELEGRAM_BOT_TOKEN</key>
        <string>FILL_ME</string>
        <key>TELEGRAM_CHAT_ID</key>
        <string>FILL_ME</string>
    </dict>
    <key>StartInterval</key>
    <integer>60</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/YOU/chief-of-staff/logs/wa-scheduler-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/YOU/chief-of-staff/logs/wa-scheduler-stderr.log</string>
</dict>
</plist>
