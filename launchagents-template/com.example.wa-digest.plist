<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Template: WhatsApp daily digest. Fires at 18:30 local time.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.example.wa-digest</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/node</string>
        <string>/Users/YOU/chief-of-staff/scripts/wa-digest.mjs</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>/Users/YOU</string>
        <key>PROJECT_ROOT</key>
        <string>/Users/YOU/chief-of-staff</string>
        <key>TELEGRAM_BOT_TOKEN</key>
        <string>FILL_ME</string>
        <key>TELEGRAM_CHAT_ID</key>
        <string>FILL_ME</string>
    </dict>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>18</integer>
        <key>Minute</key>
        <integer>30</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/Users/YOU/chief-of-staff/logs/wa-digest-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/YOU/chief-of-staff/logs/wa-digest-stderr.log</string>
</dict>
</plist>
